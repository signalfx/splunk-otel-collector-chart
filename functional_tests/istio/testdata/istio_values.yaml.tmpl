splunkObservability:
   realm:       CHANGEME
   accessToken: CHANGEME
   ingestUrl: {{ .IngestURL }}
   apiUrl: {{ .ApiURL }}

autodetect:
  istio: true

agent:
  controlPlaneMetrics:
    apiserver:
      enabled: false
    controllerManager:
      enabled: false
    coredns:
      enabled: false
    etcd:
      enabled: false
    proxy:
      enabled: false
    scheduler:
      enabled: false


clusterReceiver:
  enabled: false

environment: dev
clusterName: dev-operator
