splunkObservability:
   realm:       CHANGEME
   accessToken: CHANGEME
   apiUrl: {{ .ApiURL }}
   ingestUrl: {{ .IngestURL }}

clusterName: test-cluster

agent:
  tokenPassthrough: true

gateway:
  enabled: true
  replicaCount: 1
  resources:
    limits:
      cpu: 200m
      memory: 256Mi
  config:
    exporters:
      otlp_http:
        traces_endpoint: {{ .OTLPSink }}/v2/trace/otlp

clusterReceiver:
  enabled: false
